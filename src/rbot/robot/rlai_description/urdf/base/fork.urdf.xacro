<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="rlai_fork" params="parent">

    <link name="fork_link">
      <visual name="fork_left_tine_visual">
        <origin xyz="0.28 0.11 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.55 0.045 0.035"/>
        </geometry>
        <material name="fork_yellow">
          <color rgba="0.95 0.65 0.08 1.0"/>
        </material>
      </visual>

      <visual name="fork_right_tine_visual">
        <origin xyz="0.28 -0.11 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.55 0.045 0.035"/>
        </geometry>
        <material name="fork_yellow">
          <color rgba="0.95 0.65 0.08 1.0"/>
        </material>
      </visual>

      <visual name="fork_backrest_visual">
        <origin xyz="0.02 0 0.14" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.32 0.24"/>
        </geometry>
        <material name="fork_dark">
          <color rgba="0.12 0.12 0.12 1.0"/>
        </material>
      </visual>

      <collision name="fork_left_tine_collision">
        <origin xyz="0.28 0.11 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.55 0.045 0.035"/>
        </geometry>
      </collision>

      <collision name="fork_right_tine_collision">
        <origin xyz="0.28 -0.11 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.55 0.045 0.035"/>
        </geometry>
      </collision>

      <collision name="fork_backrest_collision">
        <origin xyz="0.02 0 0.14" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.32 0.24"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0.18 0 0.06" rpy="0 0 0"/>
        <mass value="8.0"/>
        <inertia ixx="0.12" ixy="0.0" ixz="0.0"
                 iyy="0.28" iyz="0.0"
                 izz="0.34"/>
      </inertial>
    </link>

    <joint name="fork_lift_joint" type="prismatic">
      <parent link="${parent}"/>
      <child link="fork_link"/>
      <origin xyz="0.28 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="0.20" effort="2000.0" velocity="0.10"/>
      <dynamics damping="50.0" friction="5.0"/>
    </joint>

  </xacro:macro>

</robot>
