<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="rlai_base">

    <!-- ── Virtual ground-plane footprint ─────────────────────────────── -->
    <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">
      <parent link="base_footprint"/>
      <child  link="base_link"/>
      <!-- Raise base_link by one wheel radius so wheels sit on z=0 -->
      <origin xyz="0 0 0.0625" rpy="0 0 0"/>
    </joint>

    <!-- ── Physical chassis ───────────────────────────────────────────── -->
    <link name="base_link">
      <visual name="chassis_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://rlai_meshes/meshes/chassis.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="chassis_dark_metal">
          <color rgba="0.18 0.18 0.20 1.0"/>
        </material>
      </visual>
      <!-- Logo inlays: colored fills for the engraved letter cavities -->
      <visual name="logo_robolabs_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://rlai_meshes/meshes/logo_robolabs.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="logo_white">
          <color rgba="0.9 0.9 0.9 1.0"/>
        </material>
      </visual>
      <visual name="logo_ai_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://rlai_meshes/meshes/logo_ai.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="logo_green">
          <color rgba="0.145 0.847 0.396 1.0"/>
        </material>
      </visual>
      <collision>
        <!-- Origin raised so box bottom sits at wheel-axle height (z=0.0625 in world).
             Without this offset the 0.15 m-tall box bottom = base_link_z - 0.075
             = 0.0625 - 0.075 = -0.0125 m, i.e. it clips through the ground plane.
             Gazebo then pushes the whole robot upward, lifting the wheels off the
             floor and making them spin freely with no traction. -->
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <!-- Bounding box: 0.50 m (L) × 0.40 m (W) × 0.15 m (H) -->
          <box size="0.50 0.40 0.15"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="15.0"/>
        <!--
          Solid box inertia (15 kg, 0.50×0.40×0.15 m):
            Ixx = m(w²+h²)/12 = 15×(0.16+0.0225)/12 = 0.2281
            Iyy = m(l²+h²)/12 = 15×(0.25+0.0225)/12 = 0.3406
            Izz = m(l²+w²)/12 = 15×(0.25+0.16)/12   = 0.5125
          (Values here are for centre-of-mass aligned box)
        -->
        <inertia ixx="0.2281" ixy="0.0" ixz="0.0"
                 iyy="0.3406" iyz="0.0"
                 izz="0.5125"/>
      </inertial>
    </link>

  </xacro:macro>
</robot>
