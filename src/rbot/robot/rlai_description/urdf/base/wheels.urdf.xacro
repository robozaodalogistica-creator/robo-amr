<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ── Single-wheel macro ─────────────────────────────────────────── -->
  <!--
    prefix          : "left" or "right"
    reflect         :  1 (left, +Y side)  or  -1 (right, -Y side)
    wheel_separation: centre-to-centre distance between driven wheels (m)
    wheel_radius    : wheel radius (m)
  -->
  <xacro:macro name="rlai_wheel"
               params="prefix reflect wheel_separation wheel_radius">

    <link name="${prefix}_wheel_link">
      <visual>
        <!-- rpy="π/2 0 0" rotates the STL wheel axis (Z) onto the robot's
             lateral axis (Y) so the wheel spins around Y correctly.         -->
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="package://rlai_meshes/meshes/wheel.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="rubber_black">
          <color rgba="0.08 0.08 0.08 1.0"/>
        </material>
      </visual>
      <!-- Wheel cap discs rendered in a contrasting silver -->
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="package://rlai_meshes/meshes/wheel_cap.stl"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="wheel_cap_silver">
          <color rgba="0.75 0.75 0.80 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="0.040"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.5"/>
        <!--
          Solid cylinder (r=0.0625, l=0.040, m=1.5):
            Ixx=Iyy = m(3r²+l²)/12 = 1.5×(3×0.00390625+0.0016)/12 = 0.001665
            Izz     = mr²/2         = 1.5×0.00390625/2               = 0.002930
        -->
        <inertia ixx="0.001665" ixy="0.0" ixz="0.0"
                 iyy="0.001665" iyz="0.0"
                 izz="0.002930"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="0.0 ${reflect * wheel_separation / 2.0} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.05"/>
      <limit effort="10.0" velocity="5.0"/>
    </joint>

  </xacro:macro>

  <xacro:macro name="rlai_wheels" params="wheel_separation wheel_radius">

    <xacro:rlai_wheel prefix="left"  reflect="1"
                      wheel_separation="${wheel_separation}"
                      wheel_radius="${wheel_radius}"/>
    <xacro:rlai_wheel prefix="right" reflect="-1"
                      wheel_separation="${wheel_separation}"
                      wheel_radius="${wheel_radius}"/>

    <!-- Four passive casters use a swivel joint plus a rolling wheel joint; wheel bottoms align with the drive wheels. -->
    <xacro:macro name="rlai_caster" params="name x y">

      <!-- 1. Swivel housing (rotates freely around Z) -->
      <link name="${name}_caster_swivel_link">
        <visual>
          <!-- Fork bracket: centred 19 mm below swivel pivot -->
          <origin xyz="0 0 -0.019" rpy="0 0 0"/>
          <geometry><box size="0.018 0.028 0.022"/></geometry>
          <material name="caster_fork"><color rgba="0.65 0.65 0.65 1.0"/></material>
        </visual>
        <inertial>
          <mass value="0.05"/>
          <inertia ixx="0.000001" ixy="0" ixz="0"
                   iyy="0.000001" iyz="0"
                   izz="0.000001"/>
        </inertial>
      </link>
      <joint name="${name}_caster_swivel_joint" type="continuous">
        <parent link="base_link"/>
        <child  link="${name}_caster_swivel_link"/>
        <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.0005" friction="0.0"/>
      </joint>

      <!-- 2. Caster wheel (rolls around Y, centre at z=-0.0375 in base_link) -->
      <link name="${name}_caster_wheel_link">
        <visual>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <geometry><cylinder radius="0.025" length="0.020"/></geometry>
          <material name="caster_rubber"><color rgba="0.08 0.08 0.08 1.0"/></material>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <geometry><cylinder radius="0.025" length="0.020"/></geometry>
        </collision>
        <inertial>
          <mass value="0.15"/>
          <!-- Cylinder m=0.15 r=0.025 h=0.020: Ixx=Iyy=m(3r²+h²)/12, Izz=mr²/2 -->
          <inertia ixx="0.0000297" ixy="0" ixz="0"
                   iyy="0.0000297" iyz="0"
                   izz="0.0000469"/>
        </inertial>
      </link>
      <joint name="${name}_caster_wheel_joint" type="continuous">
        <parent link="${name}_caster_swivel_link"/>
        <child  link="${name}_caster_wheel_link"/>
        <origin xyz="0 0 -0.036" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.0005" friction="0.0"/>
      </joint>

    </xacro:macro>

    <xacro:rlai_caster name="front_left"  x=" 0.20" y=" 0.14"/>
    <xacro:rlai_caster name="front_right" x=" 0.20" y="-0.14"/>
    <xacro:rlai_caster name="rear_left"   x="-0.20" y=" 0.14"/>
    <xacro:rlai_caster name="rear_right"  x="-0.20" y="-0.14"/>

  </xacro:macro>

</robot>
